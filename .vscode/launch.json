{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django Runserver",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}server//manage.py",
      "args": [
        "runserver",
        "--noreload"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Django Runserver (with custom port)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": [
        "runserver",
        "8080",
        "--noreload"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal"
    },
    {
      "name": "MCP Server",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/server/manage.py",
      "args": [
        "run_mcp_server",
        "--host",
        "0.0.0.0",
        "--port",
        "8001",
        "--transport",
        "streamable-http"
      ],
      "django": true,
      "justMyCode": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Run Tests (pytest)",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "-k",
        "my_test"
      ],
      "justMyCode": true
    }
  ]
}
